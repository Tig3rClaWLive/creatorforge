'use client';
import { useEffect, useState } from 'react';
export default function Admin(){const [pending,setPending]=useState<any[]>([]); const [reports,setReports]=useState<any[]>([]); const [users,setUsers]=useState<any[]>([]); const [stats,setStats]=useState<any>(null); const [msg,setMsg]=useState(''); async function load(){const [p,r,u,s]=await Promise.all([fetch('/api/admin/pending'),fetch('/api/admin/reports'),fetch('/api/admin/users'),fetch('/api/admin/stats')]); setPending(p.ok?(await p.json()).uploads||[]:[]); setReports(r.ok?(await r.json()).reports||[]:[]); setUsers(u.ok?(await u.json()).users||[]:[]); setStats(s.ok?await s.json():null);} useEffect(()=>{load()},[]); async function mod(id:string,action:string){const reason=action==='reject'?prompt('Ablehnungsgrund?')||'': ''; const r=await fetch('/api/admin/moderate',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({id,action,reason})}); const j=await r.json(); setMsg(j.message||j.error); load();} async function role(id:string,role:string){const r=await fetch('/api/admin/users',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({id,role})}); const j=await r.json(); setMsg(j.message||j.error); load();} async function del(id:string){if(!confirm('Upload wirklich löschen?'))return; const r=await fetch('/api/admin/delete-upload',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({id,reason:'Admin gelöscht'})}); const j=await r.json(); setMsg(j.message||j.error); load();} return <section className="container py-16"><h1 className="text-5xl font-black">Adminbereich</h1>{msg&&<p className="mt-4 text-orange-300">{msg}</p>}{stats&&<div className="mt-8 grid gap-4 md:grid-cols-4">{Object.entries(stats).map(([k,v])=><div className="card p-5" key={k}><p className="text-sm text-zinc-400">{k}</p><b className="text-3xl">{String(v)}</b></div>)}</div>}<h2 className="mt-12 text-3xl font-bold">Wartende Uploads</h2><div className="mt-4 space-y-4">{pending.map(u=><div className="card p-5" key={u.id}><h3 className="text-xl font-bold">{u.title}</h3><p className="text-sm text-zinc-400">{u.category} · {u.created_at}</p><p className="mt-2">{u.description}</p><div className="mt-4 flex gap-3"><button className="btn btn-primary" onClick={()=>mod(u.id,'approve')}>Freigeben</button><button className="btn btn-soft" onClick={()=>mod(u.id,'reject')}>Ablehnen</button><button className="btn btn-soft" onClick={()=>del(u.id)}>Löschen</button></div></div>)}{!pending.length&&<p className="text-zinc-400">Keine offenen Uploads.</p>}</div><h2 className="mt-12 text-3xl font-bold">Meldungen</h2><div className="mt-4 space-y-3">{reports.map(r=><div className="card p-4" key={r.id}><b>{r.title||r.upload_id}</b><p className="text-sm text-zinc-400">{r.reason}</p><p>{r.message}</p></div>)}</div><h2 className="mt-12 text-3xl font-bold">Benutzerrollen</h2><div className="mt-4 space-y-3">{users.map(u=><div className="card flex flex-col justify-between gap-3 p-4 md:flex-row md:items-center" key={u.id}><span>{u.email} · {u.role}</span><select className="input max-w-48" defaultValue={u.role} onChange={e=>role(u.id,e.target.value)}><option value="creator">creator</option><option value="moderator">moderator</option><option value="admin">admin</option></select></div>)}</div></section>}
